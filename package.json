{
  "name": "nexabooth",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "deploy": "npm run build && wrangler pages deploy dist",
    "db:migrate:local": "wrangler d1 execute nexabooth-db --local --file=migrations/0001_init.sql",
    "db:migrate:remote": "wrangler d1 execute nexabooth-db --remote --file=migrations/0001_init.sql",
    "db:seed:local": "wrangler d1 execute nexabooth-db --local --file=migrations/0002_seed.sql",
    "db:seed:remote": "wrangler d1 execute nexabooth-db --remote --file=migrations/0002_seed.sql",
    "pages:dev": "wrangler pages dev dist --d1 DB=nexabooth-db"
  },
  "dependencies": {
    "hono": "^4.4.13",
    "lucide-react": "^0.400.0",
    "qrcode": "^1.5.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.24.1"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240718.0",
    "@types/qrcode": "^1.5.5",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "postcss": "^8.4.39",
    "tailwindcss": "^3.4.6",
    "typescript": "^5.5.3",
    "vite": "^5.3.4",
    "wrangler": "^3.67.1"
  }
}
